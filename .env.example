# Optional. If set, core/phrasing.py will ask Claude to rephrase the
# deterministic suggestions/summary more naturally (with verification that
# it didn't change the score or drop a named gap). If unset, the tool runs
# fully offline using fixed templates -- this is the default and is what the
# test harness uses.
ANTHROPIC_API_KEY=

# Port the streamable-http MCP server binds to internally (default 8000).
PORT=

# Not implemented in this build. Placeholder for wiring the MCP server to
# OKX.AI's x402 pay-per-call billing step (see mcp_server/billing_stub.py).
# Confirmed via OKX's own onchainos-skills docs: paid A2MCP endpoints are
# expected to speak x402, not a generic "USDT on X Layer" flow.
OKX_X402_CONFIG=
