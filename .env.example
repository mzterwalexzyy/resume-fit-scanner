# Optional. If set, core/phrasing.py will ask an LLM to rephrase the
# deterministic suggestions/summary more naturally (with verification that
# it didn't change the score or drop a named gap). If unset, the tool runs
# fully offline using fixed templates -- this is the default and is what the
# test harness uses. Provider priority: ANTHROPIC_API_KEY, then
# NVIDIA_API_KEY, then OPENROUTER_API_KEY -- first one set wins.
ANTHROPIC_API_KEY=

# Optional alternative -- NVIDIA's NIM API (OpenAI-compatible), checked
# second. Get a key at https://build.nvidia.com. Hosted 400B-scale models
# can take 15-20+ seconds even for a short reply; on any failure or timeout
# this silently falls back to the deterministic template.
NVIDIA_API_KEY=
# Defaults to z-ai/glm-5.2 if unset.
NVIDIA_MODEL=

# Optional alternative -- OpenRouter (OpenAI-compatible), checked last. Get a
# free key at https://openrouter.ai/settings/keys. Free-tier models can be
# rate-limited upstream; on any failure this silently falls back to the
# deterministic template, same as the other providers.
OPENROUTER_API_KEY=
# Defaults to nousresearch/hermes-3-llama-3.1-405b:free if unset.
OPENROUTER_MODEL=

# Port the streamable-http MCP server binds to internally (default 8000).
PORT=

# Not implemented in this build. Placeholder for wiring the MCP server to
# OKX.AI's x402 pay-per-call billing step (see mcp_server/billing_stub.py).
# Confirmed via OKX's own onchainos-skills docs: paid A2MCP endpoints are
# expected to speak x402, not a generic "USDT on X Layer" flow.
OKX_X402_CONFIG=
